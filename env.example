# Application
DJANGO_SECRET_KEY=<generate-local-django-secret-key>
DJANGO_SETTINGS_MODULE=libraryops.config.settings.local
DATABASE_URL=postgres://<local-postgres-user>:<local-postgres-password>@localhost:5432/<local-db-name>

# Production settings require explicit secure values and fail loudly if they are missing.
SECRET_KEY=<required-production-secret-key>
DJANGO_ALLOWED_HOSTS=<comma-separated-production-hostnames>

# Optional hosted AI/search/research. Store real values in local .env, user-level tool config,
# CI secrets, or approved MCP env blocks only; never commit raw keys.
OPENAI_API_KEY=<optional-local-only-openai-api-key>
EXA_API_KEY=<optional-local-only-exa-api-key>
CONTEXT7_API_KEY=<optional-local-only-context7-api-key>
ANTHROPIC_API_KEY=<optional-local-only-anthropic-api-key>
PERPLEXITY_API_KEY=<optional-local-only-perplexity-api-key>
GOOGLE_API_KEY=<optional-local-only-google-api-key>
OPENROUTER_API_KEY=<optional-local-only-openrouter-api-key>

# Optional allauth social providers. Set both values for a provider to enable it.
DJANGO_ALLAUTH_GOOGLE_CLIENT_ID=<optional-google-oauth-client-id>
DJANGO_ALLAUTH_GOOGLE_SECRET=<optional-google-oauth-client-secret>
DJANGO_ALLAUTH_GITHUB_CLIENT_ID=<optional-github-oauth-client-id>
DJANGO_ALLAUTH_GITHUB_SECRET=<optional-github-oauth-client-secret>

# Figma remote MCP uses local Codex OAuth login, not committed environment tokens:
#   codex mcp add figma --url https://mcp.figma.com/mcp
#   codex mcp login figma

# Seed/demo
LIBRARYOPS_DEMO_ACCESS_CODE=<local-demo-access-code>
