{
  "$schema": "https://repomix.com/schemas/latest/schema.json",
  "output": {
    "filePath": "repomix-output.xml",
    "style": "xml",
    "removeComments": false,
    "removeEmptyLines": false,
    "showLineNumbers": true,
    "copyToClipboard": false,
    "topFilesLength": 20
  },
  "include": [
    "AGENTS.md",
    "README.md",
    "llms.txt",
    "env.example",
    ".gitignore",
    ".npmrc",
    ".vale.ini",
    ".valeignore",
    ".vale/styles/**/*.yml",
    ".alexrc",
    "cspell.json",
    "lychee.toml",
    ".markdownlint-cli2.jsonc",
    ".gitleaks.toml",
    ".semgrep.yml",
    "sgconfig.yml",
    ".github/**/*.yml",
    ".github/CODEOWNERS",
    ".github/pull_request_template.md",
    ".husky/**/*",
    ".codex/**/*.toml",
    ".codex/agents/**/*.toml",
    ".codex/**/*.json",
    ".codex/hooks/**/*.py",
    ".codex/rules/**/*.rules",
    ".agents/skills/**/*.md",
    ".agents/skills/**/references/**/*.md",
    ".taskmaster/AGENTS.md",
    ".taskmaster/config.example.json",
    ".taskmaster/docs/**/*.md",
    ".taskmaster/templates/**/*.md",
    ".specify/memory/constitution.md",
    "docs/**/*.md",
    "specs/**/*.md",
    "evals/**/*.md",
    "evals/**/*.yaml",
    "evals/**/*.yml",
    "promptfooconfig.yaml",
    "policy/**/*.rego",
    "rules/**/*.yml",
    "scripts/**/*.py",
    "scripts/**/*.sh",
    "src/**/*.py",
    "tests/**/*.py",
    "templates/**/*.html",
    "static/src/**/*",
    "package.json",
    "package-lock.json",
    "pyproject.toml",
    "uv.lock",
    "commitlint.config.cjs",
    "manage.py",
    "repomix.config.json"
  ],
  "ignore": {
    "useGitignore": true,
    "useDefaultPatterns": true,
    "customPatterns": [
      ".env",
      ".env.*",
      ".codex-local/**",
      ".rtk/**",
      ".serena/**",
      ".repomix/**",
      ".tokenix/**",
      ".headroom/**",
      "repomix-output.*",
      "media/**",
      "staticfiles/**",
      "*.sqlite3",
      "*.db",
      "*.jsonl",
      "*.parquet",
      "*.csv",
      "*secret*",
      "*credential*",
      "reports/**",
      "SHA256SUMS.txt",
      "VERIFIER_HANDOFF_MANIFEST.json",
      "*.zip",
      "*.tar",
      "*.tar.gz"
    ]
  },
  "security": {
    "enableSecurityCheck": true
  },
  "tokenCount": {
    "encoding": "o200k_base"
  }
}
