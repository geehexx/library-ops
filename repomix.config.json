{
  "$schema": "https://repomix.com/schemas/latest/schema.json",
  "output": {
    "filePath": "repomix-output.xml",
    "style": "xml",
    "removeComments": false,
    "removeEmptyLines": false,
    "showLineNumbers": true,
    "copyToClipboard": false,
    "topFilesLength": 20
  },
  "include": [
    "AGENTS.md",
    ".codex/**/*.toml",
    ".codex/**/*.json",
    ".codex/hooks/**/*.py",
    ".agents/skills/**/*.md",
    ".taskmaster/docs/**/*.md",
    ".taskmaster/tasks/*.json",
    ".specify/**/*.md",
    "docs/process/**/*.md",
    "src/libraryops/accounts/roles.py",
    "package.json",
    "pyproject.toml",
    "manage.py",
    "repomix.config.json"
  ],
  "ignore": {
    "useGitignore": true,
    "useDefaultPatterns": true,
    "customPatterns": [
      ".env",
      ".env.*",
      ".codex-local/**",
      ".rtk/**",
      ".serena/**",
      ".repomix/**",
      ".tokenix/**",
      ".headroom/**",
      "repomix-output.*",
      "media/**",
      "staticfiles/**",
      "*.sqlite3",
      "*.db",
      "*.jsonl",
      "*.parquet",
      "*.csv",
      "*secret*",
      "*credential*",
      "reports/**",
      "*.zip",
      "*.tar",
      "*.tar.gz"
    ]
  },
  "security": {
    "enableSecurityCheck": true
  },
  "tokenCount": {
    "encoding": "o200k_base"
  }
}
